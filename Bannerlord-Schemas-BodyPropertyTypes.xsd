<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <xs:complexType name="BodyPropertyType">
        <xs:attribute name="version" type="xs:int" default="4" />
        <xs:attribute name="age" type="xs:float" />
        <xs:attribute name="weight" type="xs:float" />
        <xs:attribute name="build" type="xs:float" />
        <xs:attribute name="key">
            <xs:simpleType>
                <xs:restriction base="xs:string">
                    <xs:pattern value="[a-zA-Z0-9]{128}" />
                </xs:restriction>
            </xs:simpleType>
        </xs:attribute>
    </xs:complexType>

