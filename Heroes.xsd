<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <xs:include schemaLocation="Bannerlord-Schemas-BodyPropertyTypes.xsd" />
    <xs:include schemaLocation="Bannerlord-Schemas-ObjectTypes.xsd" />
    
    <xs:element name="Heroes">
        <xs:complexType>
            <xs:choice>
                <xs:element name="Hero" minOccurs="0" maxOccurs="unbounded">
                    <xs:complexType>
                        <xs:attribute name="id" type="xs:string" />
                        <xs:attribute name="alive" type="xs:boolean" />
                        <xs:attribute name="faction" type="FactionObjectType" />
                        <xs:attribute name="text" type="xs:string" />
                        <xs:attribute name="preferred_upgrade_formation" type="xs:string" />
                        <xs:attribute name="father" type="HeroObjectType" />
                        <xs:attribute name="mother" type="HeroObjectType" />
                        <xs:attribute name="spouse" type="HeroObjectType" />
                    </xs:complexType>
                </xs:element>
            </xs:choice>
        </xs:complexType>
    </xs:element>

</xs:schema>